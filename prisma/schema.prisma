generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model User {
  firstName       String?
  lastName        String?        @default("")
  money           Decimal        @default(10000.0) @db.Decimal(18, 6)
  admin           Boolean        @default(false)
  email           String         @unique
  id              Int            @id @default(autoincrement())
  accounts        Account[]
  approvedMarkets Market[]       @relation("ApprovedMarkets")
  createdMarkets  Market[]       @relation("CreatedMarkets")
  resolvedMarkets Market[]       @relation("ResolvedMarkets")
  notifications   Notification[]
  positions       Position[]
  trades          Trade[]
}

model Market {
  id                Int          @id @default(autoincrement())
  title             String       @unique
  description       String
  liquidity         Int          @default(10)
  creatorId         Int
  status            MarketStatus @default(OPEN)
  closeTime         DateTime
  resolvedOutcomeId Int?         @unique
  approvedById      Int?
  createdAt         DateTime     @default(now())
  approvedAt        DateTime?
  resolvedAt        DateTime?
  resolvedById      Int?
  approvedBy        User?        @relation("ApprovedMarkets", fields: [approvedById], references: [id])
  creator           User         @relation("CreatedMarkets", fields: [creatorId], references: [id])
  resolvedBy        User?        @relation("ResolvedMarkets", fields: [resolvedById], references: [id])
  resolvedOutcome   Outcome?     @relation("ResolvedOutcome", fields: [resolvedOutcomeId], references: [id])
  outcomes          Outcome[]    @relation("MarketOutcomes")
  positions         Position[]
  trades            Trade[]

  @@index([status])
  @@index([closeTime])
  @@index([creatorId])
}

model Outcome {
  id                Int        @id @default(autoincrement())
  marketId          Int
  name              String
  sharesOutstanding Int        @default(0)
  resolvedMarket    Market?    @relation("ResolvedOutcome")
  market            Market     @relation("MarketOutcomes", fields: [marketId], references: [id], onDelete: Cascade)
  positions         Position[]
  trades            Trade[]

  @@unique([marketId, name])
  @@index([marketId])
}

model Trade {
  id        Int      @id @default(autoincrement())
  marketId  Int
  userId    Int
  shares    Decimal  @db.Decimal(18, 6)
  price     Decimal  @db.Decimal(18, 6)
  cost      Decimal  @db.Decimal(18, 6)
  createdAt DateTime @default(now())
  outcomeId Int
  market    Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  outcome   Outcome  @relation(fields: [outcomeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([marketId])
  @@index([userId])
  @@index([outcomeId])
}

model Position {
  id          Int      @id @default(autoincrement())
  userId      Int
  marketId    Int
  outcomeId   Int
  shares      Decimal  @default(0) @db.Decimal(18, 6)
  avgCost     Decimal  @default(0) @db.Decimal(18, 6)
  realizedPnl Decimal  @default(0) @db.Decimal(18, 6)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  market      Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  outcome     Outcome  @relation(fields: [outcomeId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, outcomeId])
  @@index([userId])
  @@index([userId, marketId])
  @@index([outcomeId])
}

model Notification {
  userId         Int
  type           NotificationType
  title          String
  body           String
  read           Boolean          @default(false)
  createdAt      DateTime         @default(now())
  id             Int              @id @default(autoincrement())
  resolutionType ResolutionType?
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
  @@index([createdAt])
}

enum MarketStatus {
  PENDING
  OPEN
  CLOSED
  RESOLVED
}

enum NotificationType {
  TRADE_BUY
  TRADE_SELL
  MARKET_REQUEST
  MARKET_APPROVED
  MARKET_REJECTED
  RESOLUTION
}

enum ResolutionType {
  WIN
  LOSS
  REFUND
}
