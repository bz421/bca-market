// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MarketStatus {
  PENDING
  OPEN
  CLOSED
  RESOLVED
}

model Account {
  id                String  @id @default(cuid())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model User {
  id              Int        @id @default(autoincrement())
  firstName       String?
  lastName        String?    @default("")
  email           String     @unique
  accounts        Account[]
  money           Decimal    @default(1000.0) @db.Decimal(18, 4)
  admin           Boolean    @default(false)
  createdMarkets  Market[]   @relation("CreatedMarkets")
  approvedMarkets Market[]   @relation("ApprovedMarkets")
  resolvedMarkets Market[]   @relation("ResolvedMarkets")
  trades          Trade[]
  positions       Position[]
}

model Market {
  id                Int          @id @default(autoincrement())
  title             String       @unique
  description       String
  liquidity         Int          @default(50)
  creator           User         @relation("CreatedMarkets", fields: [creatorId], references: [id])
  creatorId         Int
  status            MarketStatus @default(OPEN)
  closeTime         DateTime
  resolvedOutcome   Outcome?     @relation("ResolvedOutcome", fields: [resolvedOutcomeId], references: [id])
  resolvedOutcomeId Int?
  trades            Trade[]
  approvedBy        User?        @relation("ApprovedMarkets", fields: [approvedById], references: [id])
  approvedById      Int?
  createdAt         DateTime     @default(now())
  approvedAt        DateTime?
  resolvedAt        DateTime?
  resolvedBy        User?        @relation("ResolvedMarkets", fields: [resolvedById], references: [id])
  resolvedById      Int?
  outcomes          Outcome[]    @relation("MarketOutcomes")
  positions         Position[]

  @@unique([resolvedOutcomeId])
  @@index([status])
  @@index([closeTime])
  @@index([creatorId])
}

model Outcome {
  id                Int        @id @default(autoincrement())
  market            Market     @relation("MarketOutcomes", fields: [marketId], references: [id], onDelete: Cascade)
  marketId          Int
  name              String
  sharesOutstanding Int        @default(0)
  trades            Trade[]
  resolvedMarket    Market?    @relation("ResolvedOutcome")
  positions         Position[]

  @@unique([marketId, name])
  @@index([marketId])
}

model Trade {
  id        Int      @id @default(autoincrement())
  market    Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  marketId  Int
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  shares    Decimal  @db.Decimal(18, 6)
  price     Decimal  @db.Decimal(18, 6)
  cost      Decimal  @db.Decimal(18, 4)
  createdAt DateTime @default(now())
  outcome   Outcome  @relation(fields: [outcomeId], references: [id], onDelete: Cascade)
  outcomeId Int

  @@index([marketId])
  @@index([userId])
  @@index([outcomeId])
}

model Position {
  id          Int      @id @default(autoincrement())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      Int
  market      Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  marketId    Int
  outcome     Outcome  @relation(fields: [outcomeId], references: [id], onDelete: Cascade)
  outcomeId   Int
  shares      Decimal  @default(0) @db.Decimal(18, 6)
  avgCost     Decimal  @default(0) @db.Decimal(18, 6)
  realizedPnl Decimal  @default(0) @db.Decimal(18, 4)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, outcomeId])
  @@index([userId])
  @@index([userId, marketId])
  @@index([outcomeId])
}
